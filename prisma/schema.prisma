enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email    String @unique(map: "user_email_idx")
  username String @unique(map: "users_username_key")
  password String

  firstName String?
  lastName  String?
  avatar    String?

  role   Role   @default(USER)
  status Status @default(INACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  familyMembers FamilyMember[]

  @@map("users")
}

model FamilyMember {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String
  role   String?
  gender Gender?

  birthDate  DateTime?
  birthPlace String?

  deathDate  DateTime?
  deathPlace String?
  isAlive    Boolean   @default(true)

  userId   String  @db.Uuid
  parentId String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  parent   FamilyMember?  @relation("FamilyHierarchy", fields: [parentId], references: [id])
  children FamilyMember[] @relation("FamilyHierarchy")

  @@index([userId])
  @@index([parentId])
  @@map("family_members")
}

model Member {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  role      String
  bio       String
  image     String
  createdAt DateTime @default(now())
}

model Settings {
  id              String  @id @default(uuid())
  siteTitle       String?
  siteKeywords    String?
  siteDescription String?
  siteUrl         String?

  isSMTP     Boolean? @default(false)
  host       String?
  username   String?
  password   String?
  port       Int?
  auth       Boolean?
  encryption String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
