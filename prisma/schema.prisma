enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Relationship {
  PARENT
  CHILD
  SPOUSE
  STEP_CHILD
  EX_SPOUSE
}

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email    String @unique(map: "user_email_idx")
  username String @unique(map: "users_username_key")
  password String

  firstName String?
  lastName  String?
  avatar    String?

  role   Role   @default(USER)
  status Status @default(INACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  familyMembers FamilyMember[]

  @@map("users")
}

model FamilyMember {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  image String
  name  String

  gender           Gender?
  birthDate        DateTime?
  birthPlace       String?
  isAlive          Boolean   @default(true)
  currentResidence String?

  deathDate    DateTime?
  deathPlace   String?
  causeOfDeath String?

  marriageDate  DateTime?
  marriagePlace String?

  spouseMaidenName String?
  spouseFather     String?
  spouseMother     String?

  profession String?
  email      String?
  phone      String?

  userId   String  @db.Uuid
  parentId String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  parent   FamilyMember?  @relation("FamilyHierarchy", fields: [parentId], references: [id])
  children FamilyMember[] @relation("FamilyHierarchy")

  @@index([userId])
  @@index([parentId])
  @@map("family_members")
}

model Member {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  role      String
  bio       String
  image     String
  createdAt DateTime @default(now())
}

model Settings {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteTitle       String?
  siteKeywords    String?
  siteDescription String?
  siteUrl         String?
  logo            String?
  favicon         String?

  isSMTP     Boolean? @default(false)
  host       String?
  username   String?
  password   String?
  port       Int?
  auth       Boolean?
  encryption String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pageTitle   String?
  pageIcon    String?
  pageContent String?
  status      Status   @default(INACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
}
